# ============================================================
# StockApp - Variables d'environnement
# ============================================================

# Serveur
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stockapp
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# JWT - IMPORTANT: utiliser une valeur aléatoire longue et complexe
JWT_SECRET=your_very_long_and_secret_jwt_key_replace_in_production_min_64_chars
JWT_EXPIRES_IN=24h

# Sécurité
BCRYPT_ROUNDS=12
